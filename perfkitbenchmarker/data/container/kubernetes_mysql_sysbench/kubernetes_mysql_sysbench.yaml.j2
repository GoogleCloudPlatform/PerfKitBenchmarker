{% if create_storage_class -%}
apiVersion: storage.k8s.io/v1
kind: StorageClass
metadata:
  name: {{ storage_class }}
  labels:
    app.kubernetes.io/managed-by: pkb
provisioner: {{ storage_provisioner }}
volumeBindingMode: WaitForFirstConsumer
reclaimPolicy: Delete
allowVolumeExpansion: true
parameters:
  type: {{ storage_type }}
---
{%- endif %}

{% if k8s_namespace and k8s_namespace != 'default' -%}
apiVersion: v1
kind: Namespace
metadata:
  name: {{ k8s_namespace }}
  labels:
    app.kubernetes.io/managed-by: pkb
---
{%- endif %}

apiVersion: v1
kind: Secret
metadata:
  name: mysql-ssl-secret
  labels:
    app.kubernetes.io/managed-by: pkb
  {% if k8s_namespace -%}
  namespace: {{ k8s_namespace }}
  {%- endif %}
data:
  ca.pem: {{ ca_pem }}
  client-cert.pem: {{ client_cert_pem }}
  client-key.pem: {{ client_key_pem }}
  server-cert.pem: {{ server_cert_pem }}
  server-key.pem: {{ server_key_pem }}

---

apiVersion: v1
kind: ConfigMap
metadata:
  name: mysql-config
  labels:
    app.kubernetes.io/managed-by: pkb
  {% if k8s_namespace -%}
  namespace: {{ k8s_namespace }}
  {%- endif %}
data:
  default-auth.cnf: |
    [mysqld]
    datadir                             = /var/lib/mysql/data
    ssl-ca=/etc/mysql/ssl/ca.pem
    ssl-cert=/etc/mysql/ssl/server-cert.pem
    ssl-key=/etc/mysql/ssl/server-key.pem
    require_secure_transport            = ON
    secure_file_priv                    = ""
    max_connections                     = 4100
    back_log                            = 1500
    table_open_cache                    = 200000
    table_open_cache_instances          = 32
    max_prepared_stmt_count             = 512000
    skip-name-resolve
    skip-character-set-client-handshake
    performance_schema                  = 1
    binlog_row_image                    = MINIMAL

    # InnoDB settings
    innodb_buffer_pool_instances        = 16
    innodb_buffer_pool_size             = 100G
    innodb_redo_log_capacity            = 120G
    innodb_io_capacity                  = 80000
    innodb_io_capacity_max              = 1600000
    innodb_page_cleaners                = 16
    innodb_purge_threads                = 4
    innodb_lru_scan_depth               = 1024
    innodb_adaptive_flushing_lwm        = 10
    innodb_flushing_avg_loops           = 30
    innodb_flush_method                 = O_DIRECT_NO_FSYNC
    #innodb_numa_interleave             = 1
    innodb_change_buffering             = none
    innodb_adaptive_hash_index          = 0

    # Durability settings
    innodb_doublewrite                  = 1
    innodb_doublewrite_pages            = 64
    innodb_doublewrite_files            = 2
    innodb_flush_log_at_trx_commit      = 1
    innodb_buffer_pool_load_at_startup  = 0
    innodb_buffer_pool_dump_at_shutdown = 0

    # Logging
    slow-query-log                      = 1
    long_query_time                     = 10

---

apiVersion: v1
kind: Service
metadata:
  name: mysql-svc
  labels:
    app.kubernetes.io/managed-by: pkb
  {% if k8s_namespace -%}
  namespace: {{ k8s_namespace }}
  {%- endif %}
spec:
  ports:
  - name: mysql
    port: 3306
    protocol: TCP
    targetPort: 3306
  selector:
    app: mysql-app
  clusterIP: None

---

apiVersion: apps/v1
kind: StatefulSet
metadata:
  name: mysql
  {% if k8s_namespace -%}
  namespace: {{ k8s_namespace }}
  {%- endif %}
  labels:
    app: mysql-app
    app.kubernetes.io/managed-by: pkb
spec:
  serviceName: mysql-svc
  replicas: 1
  selector:
    matchLabels:
      app: mysql-app
  persistentVolumeClaimRetentionPolicy:
    whenDeleted: Delete
    whenScaled: Delete
  template:
    metadata:
      labels:
        app: mysql-app
        app.kubernetes.io/managed-by: pkb
    spec:
      securityContext:
        sysctls:
        - name: net.ipv4.tcp_fin_timeout
          value: "{{ tcp_fin_timeout }}"
      affinity:
        nodeAffinity:
          requiredDuringSchedulingIgnoredDuringExecution:
            nodeSelectorTerms:
            - matchExpressions:
              - key: pkb_nodepool
                operator: In
                values:
                - servers
        podAntiAffinity:
          requiredDuringSchedulingIgnoredDuringExecution:
          - labelSelector:
              matchExpressions:
              - key: app
                operator: In
                values:
                - mysql-app
            topologyKey: "kubernetes.io/hostname"
      initContainers:
        - name: prepare-data-dir
          image: busybox
          command: ["sh", "-c", "mkdir -p /var/lib/mysql/data && find /var/lib/mysql/data -mindepth 1 -delete && chown -R 999:999 /var/lib/mysql/data"]
          volumeMounts:
            - name: data
              mountPath: /var/lib/mysql
      containers:
        - name: mysql-container
          image: mysql:{{ mysql_version }}
          imagePullPolicy: Always
          command: ["/bin/sh", "-c", "exec /usr/local/bin/docker-entrypoint.sh mysqld"]
          ports:
            - containerPort: 3306
          readinessProbe:
            exec:
              command: ["sh", "-c", "mysqladmin ping -h localhost -u $MYSQL_USER -p$MYSQL_PASSWORD"]
            initialDelaySeconds: 5
            periodSeconds: 2
          env:
            - name: MYSQL_ROOT_PASSWORD
              value: {{ mysql_password }}
            - name: MYSQL_DATABASE
              value: {{ mysql_db }}
            - name: MYSQL_USER
              value: {{ mysql_user }}
            - name: MYSQL_PASSWORD
              value: {{ mysql_password }}
            - name: MYSQL_INITDB_SKIP_TZINFO
              value: "1"
          volumeMounts:
            - name: data
              mountPath: /var/lib/mysql
            - name: mysql-ssl
              mountPath: /etc/mysql/ssl
              readOnly: true
            - name: mysql-config
              mountPath: /etc/mysql/conf.d/
          resources:
            requests:
               memory: 100Gi
               cpu: "10"
            limits:
               memory: 116Gi
               cpu: "15"
      volumes:
        - name: mysql-ssl
          secret:
            secretName: mysql-ssl-secret
        - name: mysql-config
          configMap:
            name: mysql-config
  volumeClaimTemplates:
    - metadata:
        name: data
      spec:
        accessModes:
          - ReadWriteOnce
        storageClassName: {{ storage_class }}
        resources:
          requests:
            storage: "{{ storage_size }}"
