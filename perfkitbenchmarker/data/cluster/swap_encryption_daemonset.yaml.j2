      hostPID: true
      hostNetwork: true
      # Pin to the benchmark nodepool — never schedule on the dummy default pool.
      nodeSelector:
        pkb_nodepool: {{ benchmark_nodepool }}
      tolerations:
      - operator: Exists
      containers:
      - name: benchmark
        image: {{ image }}
        command:
        - bash
